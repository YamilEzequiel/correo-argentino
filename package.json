{
  "name": "ylazzari-correoargentino",
  "version": "0.1.0",
  "description": "API wrapper para el servicio de MiCorreo de Correo Argentino",
  "main": "./dist/miCorreo/index.js",
  "module": "./dist/esm/miCorreo/index.js",
  "types": "./dist/miCorreo/index.d.ts",
  "type": "commonjs",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/esm/miCorreo/index.js",
      "require": "./dist/miCorreo/index.js",
      "types": "./dist/miCorreo/index.d.ts"
    },
    "./setting": {
      "import": "./dist/esm/setting/index.js",
      "require": "./dist/setting/index.js",
      "types": "./dist/setting/index.d.ts"
    },
    "./enums": {
      "import": "./dist/esm/types/enum.js",
      "require": "./dist/types/enum.js",
      "types": "./dist/types/enum.d.ts"
    },
    "./interfaces": {
      "import": "./dist/esm/types/interface.js",
      "require": "./dist/types/interface.js",
      "types": "./dist/types/interface.d.ts"
    },
    "./types": {
      "import": "./dist/esm/types/index.js",
      "require": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "enums": [
        "./dist/types/enum.d.ts"
      ],
      "interfaces": [
        "./dist/types/interface.d.ts"
      ],
      "*": [
        "./dist/miCorreo/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "rimraf dist && npm run build:cjs && npm run build:esm && node scripts/postbuild.mjs",
    "build:cjs": "tsc",
    "build:esm": "tsc -p tsconfig.esm.json",
    "prepare": "npm run build",
    "clean": "rimraf dist",
    "playground": "tsx scripts/dev-server.ts"
  },
  "keywords": [
    "correo-argentino",
    "micorreo",
    "shipping",
    "argentina"
  ],
  "author": "Yamil Lazzari",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YamilEzequiel/correo-argentino"
  },
  "peerDependencies": {
    "axios": "^1.x"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "axios": "^1.6.0",
    "dotenv": "^16.0.0",
    "express": "^5.0.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
